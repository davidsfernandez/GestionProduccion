@page "/usuarios"
@using GestionProduccion.Models.DTOs
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize(Roles = "Administrator")]
@using GestionProduccion.Client.Services
@inject HttpClient Http
@inject ToastService ToastService
@inject NavigationManager NavigationManager
@inject JsonSerializerOptions JsonOptions

@using GestionProduccion.Client.Resources

<PageTitle>@Portuguese.User_Title</PageTitle>

<div class="container-fluid p-0 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h3 class="text-dark mb-0">@Portuguese.User_Title</h3>
        <button class="btn btn-primary shadow-sm w-100 w-md-auto" @onclick="ShowCreateModal">
            <i class="fa-solid fa-user-plus me-2"></i> @Portuguese.User_NewUser
        </button>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="card-title mb-0 fw-bold">Lista de Usuários</h5>
                </div>
                
                @if (loading)
                {
                    <div class="card-body text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">@Portuguese.Loading</span>
                        </div>
                    </div>
                }
                else if (users == null || !users.Any())
                {
                    <div class="card-body p-4">
                        <div class="alert alert-info mb-0">Nenhum usuário encontrado.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover my-0 align-middle">
                            <thead>
                                <tr class="bg-light">
                                    <th class="ps-4">@Portuguese.User_Name</th>
                                    <th>@Portuguese.User_Email</th>
                                    <th class="d-none d-lg-table-cell">ID PÚBLICO</th>
                                    <th>EQUIPE</th>
                                    <th>@Portuguese.User_Role</th>
                                    <th>@Portuguese.User_Status</th>
                                    <th class="text-end pe-4">@Portuguese.Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    <tr @key="user.Id">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "/img/avatars/avatar.jpg" : user.AvatarUrl)" 
                                                     class="rounded-circle me-3 border" width="32" height="32" alt="Avatar" />
                                                <div class="fw-bold text-dark">@user.FullName</div>
                                            </div>
                                        </td>
                                        <td>@user.Email</td>
                                        <td class="d-none d-lg-table-cell"><code class="small text-muted">@user.ExternalId.ToString().Substring(0, 8)...</code></td>
                                        <td><span class="badge bg-info-soft text-info">@(user.SewingTeamName ?? "-")</span></td>
                                        <td>
                                            <span class="badge bg-primary-soft text-primary">@TranslateRole(user.Role.ToString())</span>
                                        </td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge bg-success-soft text-success">@Portuguese.User_Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-soft text-danger">@Portuguese.User_Inactive</span>
                                            }
                                        </td>
                                        <td class="text-end pe-4">
                                            <button class="btn btn-sm btn-light me-1" @onclick="() => EditUser(user)" title="@Portuguese.Edit">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            @if (user.Email != "administrador@serona.com")
                                            {
                                                <button class="btn btn-sm btn-light text-danger" @onclick="() => DeleteUser(user.Id)" title="@Portuguese.Deactivate">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal fade show d-block animate-fade-in" tabindex="-1" style="background-color: rgba(21, 22, 40, 0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 overflow-hidden" style="border-radius: 20px;">
                <div class="modal-header bg-primary py-3 border-0">
                    <h5 class="modal-title fw-bold text-white">
                        <i class="fa-solid @(isEditing ? "fa-user-pen" : "fa-user-plus") me-2"></i>
                        @(isEditing ? Portuguese.Edit : Portuguese.Create) @Portuguese.User_User
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4 rounded-3 border-0 shadow-sm">
                            <i class="fa-solid fa-circle-exclamation me-2"></i>
                            <div class="small">@errorMessage</div>
                        </div>
                    }
                    <EditForm Model="userModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label small fw-bold text-muted">@Portuguese.User_Name</label>
                                <InputText class="form-control" @bind-Value="userModel.FullName" placeholder="@Portuguese.User_FullNamePlaceholder" />
                                <ValidationMessage For="@(() => userModel.FullName)" class="text-danger xsmall mt-1" />
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label small fw-bold text-muted">@Portuguese.User_Email</label>
                                <InputText class="form-control" @bind-Value="userModel.Email" placeholder="@Portuguese.User_EmailPlaceholder" />
                                <ValidationMessage For="@(() => userModel.Email)" class="text-danger xsmall mt-1" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">@Portuguese.User_Password @(isEditing ? "*" : "")</label>
                                <div class="input-group">
                                    <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="userModel.Password" placeholder="Min. 6 caracteres" />
                                    <button class="btn btn-outline-light border text-muted" type="button" @onclick="() => showPassword = !showPassword">
                                        <i class="fa-solid @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                </div>
                                @if(isEditing) { <small class="text-muted xsmall d-block mt-1">@Portuguese.User_PassHint</small> }
                                <ValidationMessage For="@(() => userModel.Password)" class="text-danger xsmall mt-1" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Confirmar Senha</label>
                                <div class="input-group">
                                    <InputText type="@(showConfirmPassword ? "text" : "password")" class="form-control" @bind-Value="userModel.ConfirmPassword" placeholder="Repita a senha" />
                                    <button class="btn btn-outline-light border text-muted" type="button" @onclick="() => showConfirmPassword = !showConfirmPassword">
                                        <i class="fa-solid @(showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => userModel.ConfirmPassword)" class="text-danger xsmall mt-1" />
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label small fw-bold text-muted">@Portuguese.User_Role</label>
                                <InputSelect class="form-select" @bind-Value="userModel.Role">
                                    @foreach (var role in Enum.GetValues<UserRole>())
                                    {
                                        <option @key="role" value="@role">@TranslateRole(role.ToString())</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label small fw-bold text-muted">Equipe de Costura (Opcional)</label>
                                <InputSelect class="form-select" @bind-Value="userModel.SewingTeamId">
                                    <option value="">Nenhuma equipe</option>
                                    @if (teams != null)
                                    {
                                        @foreach (var team in teams)
                                        {
                                            <option value="@team.Id">@team.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-light px-4" @onclick="CloseModal">@Portuguese.Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" disabled="@isSaving">
                                @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                <i class="fa-solid fa-save me-2"></i> @(isEditing ? Portuguese.Save : Portuguese.Create)
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserDto>? users;
    private List<SewingTeamDto>? teams;
    private bool loading = true;
    private bool showModal = false;
    private bool isEditing = false;
    private UserFormModel userModel = new();
    private int editingUserId;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string? errorMessage;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadUsers(), LoadTeams());
    }

    private async Task LoadTeams()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<SewingTeamDto>>>("api/SewingTeams", JsonOptions);
            if (response != null && response.Success) teams = response.Data;
        }
        catch { }
    }

    private async Task LoadUsers()
    {
        try
        {
            loading = true;
            var response = await Http.GetFromJsonAsync<ApiResponse<List<UserDto>>>("api/Users", JsonOptions);
            if (response != null && response.Success) users = response.Data;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            ToastService.ShowToast($"{Portuguese.Error}: {ex.Message}", ToastLevel.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateModal()
    {
        isEditing = false;
        errorMessage = null;
        userModel = new UserFormModel { Role = UserRole.Operational };
        showModal = true;
    }

    private void EditUser(UserDto user)
    {
        isEditing = true;
        errorMessage = null;
        editingUserId = user.Id;
        userModel = new UserFormModel
        {
            FullName = user.FullName,
            Email = user.Email,
            Role = user.Role,
            SewingTeamId = user.SewingTeamId
        };
        showModal = true;
    }

    private string TranslateRole(string role) => role switch
    {
        "Administrator" => Portuguese.Role_Admin,
        "Leader" => Portuguese.Role_Leader,
        "Operational" => Portuguese.Role_Operator,
        "Office" => Portuguese.Role_Office,
        _ => role
    };

    private async Task HandleSubmit()
    {
        if (isSaving) return;
        isSaving = true;
        errorMessage = null;

        try
        {
            ApiResponse<UserDto>? apiResp;
            if (isEditing)
            {
                var req = new UpdateUserRequest
                {
                    FullName = userModel.FullName,
                    Email = userModel.Email,
                    Password = string.IsNullOrWhiteSpace(userModel.Password) ? null : userModel.Password,
                    Role = userModel.Role,
                    SewingTeamId = userModel.SewingTeamId
                };
                var response = await Http.PutAsJsonAsync($"api/Users/{editingUserId}", req);
                apiResp = await response.Content.ReadFromJsonAsync<ApiResponse<UserDto>>(JsonOptions);
            }
            else
            {
                var req = new CreateUserRequest
                {
                    FullName = userModel.FullName,
                    Email = userModel.Email,
                    Password = userModel.Password,
                    Role = userModel.Role,
                    SewingTeamId = userModel.SewingTeamId
                };
                var response = await Http.PostAsJsonAsync("api/Users", req);
                apiResp = await response.Content.ReadFromJsonAsync<ApiResponse<UserDto>>(JsonOptions);
            }

            if (apiResp != null && apiResp.Success && apiResp.Data != null)
            {
                if (isEditing)
                {
                    var idx = users?.FindIndex(u => u.Id == apiResp.Data.Id) ?? -1;
                    if (idx != -1) users![idx] = apiResp.Data;
                }
                else
                {
                    users?.Add(apiResp.Data);
                }

                ToastService.ShowToast(apiResp.Message ?? (isEditing ? Portuguese.Msg_UserUpdated : Portuguese.Msg_UserCreated), ToastLevel.Success);
                showModal = false;
            }
            else
            {
                errorMessage = apiResp?.Message ?? "Erro ao salvar usuário.";
                ToastService.ShowToast(errorMessage, ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ToastService.ShowToast(errorMessage, ToastLevel.Error);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteUser(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", new object[] { Portuguese.ConfirmDeactivate }))
        {
            try 
            {
                var response = await Http.DeleteAsync($"api/Users/{id}");
                var apiResp = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
                
                if (apiResp?.Success == true)
                {
                    var u = users?.FirstOrDefault(x => x.Id == id);
                    if (u != null) users?.Remove(u);
                    ToastService.ShowToast(apiResp.Message ?? "Usuário desativado.", ToastLevel.Success);
                }
                else 
                {
                    ToastService.ShowToast(apiResp?.Message ?? "Erro ao desativar.", ToastLevel.Error);
                }
            }
            catch (Exception ex) 
            { 
                ToastService.ShowToast(ex.Message, ToastLevel.Error); 
            }
            finally
            {
                StateHasChanged();
            }
        }
    }

    private void CloseModal() => showModal = false;

    [Inject] IJSRuntime JS { get; set; } = default!;

    public class UserFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nome é obrigatório")]
        public string FullName { get; set; } = "";
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email es obligatorio")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = "";
        
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public UserRole Role { get; set; } = UserRole.Operational;
        public int? SewingTeamId { get; set; }
    }
}
