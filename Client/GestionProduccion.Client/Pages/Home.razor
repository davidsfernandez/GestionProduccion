@page "/"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Globalization
@using GestionProduccion.Models.DTOs
@using GestionProduccion.Client.Services
@using GestionProduccion.Client.Components
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISignalRService SignalR
@inject IJSRuntime JSRuntime
@inject JsonSerializerOptions JsonOptions
@inject ToastService ToastService
@implements IAsyncDisposable

@using GestionProduccion.Client.Resources

<PageTitle>@Portuguese.Dash_Title</PageTitle>

<div class="container-fluid p-0 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="text-dark mb-1 fw-bold">@Portuguese.Dash_Title</h3>
            <p class="text-muted small mb-0">@Portuguese.Dash_RealTimeMonitoring</p>
        </div>
        <div class="d-flex gap-2 w-100 w-md-auto">
             <a href="/tv-producao" target="_blank" class="btn btn-primary shadow-sm flex-grow-1 flex-md-grow-0 d-flex align-items-center justify-content-center px-4" 
                title="@Portuguese.Dash_TvMode">
                 <i class="fa-solid fa-tv me-2"></i> <span>@Portuguese.Dash_TvMode</span>
             </a>
             <button class="btn btn-white shadow-sm border" @onclick="LoadDashboard" disabled="@loading">
                 <i class="fa-solid fa-arrows-rotate @(loading ? "fa-spin" : "")"></i>
             </button>
        </div>
    </div>

    @if (loading && dashboard == null)
    {
        <div class="row">
            <div class="col-12 col-sm-6 col-xxl-3 mb-4"><SkeletonCard /></div>
            <div class="col-12 col-sm-6 col-xxl-3 mb-4"><SkeletonCard /></div>
            <div class="col-12 col-sm-6 col-xxl-3 mb-4"><SkeletonCard /></div>
            <div class="col-12 col-sm-6 col-xxl-3 mb-4"><SkeletonCard /></div>
        </div>
        <div class="row">
            <div class="col-xl-8"><div class="card p-5 text-center border-0 shadow-sm rounded-4"><div class="spinner-border text-primary mx-auto"></div></div></div>
            <div class="col-xl-4"><SkeletonCard /><div class="mt-4"><SkeletonCard /></div></div>
        </div>
    }
    else if (dashboard != null)
    {
        <!-- KPI CARDS -->
        <div class="row mb-2">
            <div class="col-12 col-sm-6 col-xxl-3 d-flex mb-4">
                <div class="card flex-fill border-0 shadow-sm animate-fade-in-up rounded-4">
                    <div class="card-body py-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h3 class="mb-1 fw-bold text-dark">@dashboard.MonthProductionQuantity</h3>
                                <p class="mb-0 text-muted small fw-bold uppercase">@Portuguese.Dash_CompletedToday</p>
                            </div>
                            <div class="bg-primary-soft p-3 rounded-3 text-primary"><i class="fa-solid fa-industry fs-4"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <AuthorizeView Roles="Administrator">
                <div class="col-12 col-sm-6 col-xxl-3 d-flex mb-4">
                    <div class="card flex-fill border-0 shadow-sm animate-fade-in-up delay-1 rounded-4">
                        <div class="card-body py-4">
                            <div class="d-flex align-items-center">
                                <div class="flex-grow-1">
                                    <h3 class="mb-1 fw-bold text-dark">@dashboard.MonthAverageCostPerPiece.ToString("C", new CultureInfo("pt-BR"))</h3>
                                    <p class="mb-0 text-muted small fw-bold uppercase">@Portuguese.OP_CostPerPiece</p>
                                </div>
                                <div class="bg-success-soft p-3 rounded-3 text-success"><i class="fa-solid fa-coins fs-4"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xxl-3 d-flex mb-4">
                    <div class="card flex-fill border-0 shadow-sm animate-fade-in-up delay-2 rounded-4">
                        <div class="card-body py-4">
                            <div class="d-flex align-items-center">
                                <div class="flex-grow-1">
                                    <h3 class="mb-1 fw-bold @(dashboard.MonthAverageMargin < 0 ? "text-danger" : "text-primary")">
                                        @dashboard.MonthAverageMargin.ToString("N1")%
                                    </h3>
                                    <p class="mb-0 text-muted small fw-bold uppercase">MARGEM MÉDIA</p>
                                </div>
                                <div class="bg-info-soft p-3 rounded-3 text-info"><i class="fa-solid fa-chart-pie fs-4"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
            </AuthorizeView>

            <div class="col-12 col-sm-6 col-xxl-3 d-flex mb-4">
                <div class="card flex-fill border-0 shadow-sm animate-fade-in-up delay-3 rounded-4">
                    <div class="card-body py-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h3 class="mb-1 fw-bold @(dashboard.DelayedOrdersCount > 0 ? "text-danger" : "text-dark")">@dashboard.DelayedOrdersCount</h3>
                                <p class="mb-0 text-muted small fw-bold uppercase">@Portuguese.Dash_ProductionStatus</p>
                            </div>
                            <div class="bg-warning-soft p-3 rounded-3 text-warning"><i class="fa-solid fa-triangle-exclamation fs-4"></i></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-8 d-flex flex-column">
                <div class="card flex-fill w-100 shadow-sm border-0 rounded-4 animate-fade-in-up mb-4 overflow-hidden">
                    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0 fw-bold">@Portuguese.Dash_WeeklyVolume</h5>
                        <span class="badge bg-light text-muted">@DateTime.Today.AddDays(-6).ToString("dd/MM") - @DateTime.Today.ToString("dd/MM")</span>
                    </div>
                    <div class="card-body py-3">
                        <div class="chart chart-sm" style="height: 300px;">
                            <canvas id="weeklyProductionChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="card flex-fill w-100 shadow-sm border-0 rounded-4 animate-fade-in-up mb-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold">@Portuguese.Dash_PerformanceUsers</h5>
                    </div>
                    <div class="card-body py-3">
                        <div class="chart chart-sm" style="height: 250px;">
                            <canvas id="workshopChart"></canvas>
                        </div>
                        @if (dashboard.ProductionByWorkshop == null || !dashboard.ProductionByWorkshop.Any())
                        {
                            <div class="text-center py-5 opacity-50">
                                <i class="fa-solid fa-chart-simple fs-1 mb-2"></i>
                                <div class="small">Sem dados de produção para exibir.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-xl-4 d-flex flex-column">
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold">@Portuguese.Dash_Workload</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @if (dashboard.TeamRanking != null && dashboard.TeamRanking.Any())
                            {
                                @foreach (var entry in dashboard.TeamRanking)
                                {
                                    <div class="list-group-item border-0 px-4 py-3">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold small">@entry.TeamName</span>
                                            <span class="text-muted xsmall">@entry.TotalProduced Peças</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary" style="width: @(entry.Efficiency)%"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="p-4 text-center text-muted small">Nenhum dado de equipe disponível.</div>
                            }
                        </div>
                    </div>
                </div>

                <AuthorizeView Roles="Administrator">
                    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-primary text-white overflow-hidden">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h5 class="card-title mb-0 fw-bold text-white">Modelos Lucrativos</h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            @if (dashboard.TopProfitableModels != null && dashboard.TopProfitableModels.Any())
                            {
                                @foreach (var item in dashboard.TopProfitableModels)
                                {
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3 text-center" style="min-width: 45px;">
                                            <div class="fw-bold">@item.AverageMargin.ToString("N0")%</div>
                                        </div>
                                        <div class="flex-grow-1 overflow-hidden">
                                            <div class="fw-bold text-truncate small">@item.Name</div>
                                            <div class="xsmall opacity-75">SKU: @item.Sku</div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-3 small opacity-75 italic">Aguardando dados financeiros...</div>
                            }
                        </div>
                    </div>
                </AuthorizeView>

                <div class="card shadow-sm border-0 rounded-4 flex-fill">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold">Últimas Atividades</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @if (activeTasks != null && activeTasks.Any())
                            {
                                @foreach (var task in activeTasks.Take(6))
                                {
                                    <div class="list-group-item border-0 px-4 py-3 d-flex align-items-start">
                                        <div class="bg-light p-2 rounded-circle me-3"><i class="fa-solid fa-check text-success"></i></div>
                                        <div>
                                            <div class="fw-bold small text-dark">@task.Title</div>
                                            <div class="xsmall text-muted">@task.AssignedUserName • @task.CreatedAt.ToLocalTime().ToString("t")</div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="p-5 text-center opacity-25">
                                    <i class="fa-solid fa-list-ul fs-1 mb-2"></i>
                                    <div class="small">Sem atividades recentes.</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardCompleteResponse? dashboard;
    private List<TaskDto>? activeTasks;
    private bool loading = false;
    private bool isTvMode = false;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        await LoadActiveTasks();

        SignalR.OnUpdateReceived += HandleUpdate;
        
        // Polished real-time refresh (every 2 mins)
        _refreshTimer = new System.Threading.Timer(async _ => 
        {
            await InvokeAsync(LoadDashboard);
        }, null, 120000, 120000);
    }

    private async void HandleUpdate(int opId, string stage, string status)
    {
        await InvokeAsync(async () => {
            await LoadDashboard();
            await LoadActiveTasks();
            StateHasChanged();
        });
    }

    private async Task LoadDashboard()
    {
        try
        {
            if (dashboard == null) loading = true;
            var response = await Http.GetFromJsonAsync<ApiResponse<DashboardCompleteResponse>>("api/Dashboard/completo", JsonOptions);
            if (response != null && response.Success)
            {
                dashboard = response.Data;
            }
            else if (response != null)
            {
                ToastService.ShowToast(response.Message ?? "Erro ao carrergar dados", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard Load Error: {ex.Message}");
        }
        finally 
        { 
            loading = false; 
            StateHasChanged(); 
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (dashboard != null)
        {
            // Always attempt to re-render charts when data is available
            try 
            {
                await JSRuntime.InvokeVoidAsync("seronaCharts.renderRevenueChart", "weeklyProductionChart", dashboard.WeeklyVolumeData, dashboard.WeeklyLabels);
                
                var workshopLabels = dashboard.ProductionByWorkshop.Select(x => x.WorkshopName).ToList();
                var workshopData = dashboard.ProductionByWorkshop.Select(x => x.Quantity).ToList();
                await JSRuntime.InvokeVoidAsync("seronaCharts.renderBarChart", "workshopChart", workshopData, workshopLabels);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Chart Interop Error: {ex.Message}");
            }
        }
    }

    private async Task LoadActiveTasks()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<TaskDto>>>("api/Tasks", JsonOptions);
            if (resp != null && resp.Success) activeTasks = resp.Data?.OrderByDescending(t => t.CreatedAt).ToList();
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        SignalR.OnUpdateReceived -= HandleUpdate;
        try { await SignalR.StopConnection(); } catch { }
    }
}
