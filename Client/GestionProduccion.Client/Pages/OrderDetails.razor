@page "/orders/{Id:int}"
@using GestionProduccion.Models.DTOs
@using GestionProduccion.Client.Services
@using GestionProduccion.Client.Services.ProductionOrders
@using GestionProduccion.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IProductionOrderQueryClient QueryClient
@inject IProductionOrderLifecycleClient LifecycleClient
@inject IProductionOrderMutationClient MutationClient
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@inject ISignalRService SignalR
@implements IAsyncDisposable

@using GestionProduccion.Client.Resources

<PageTitle>@Portuguese.OP_Details_Title - @(order?.LotCode ?? "")</PageTitle>

<div class="container-fluid p-0 animate-fade-in">
    @if (loading && order == null)
    {
        <div class="vh-100 d-flex align-items-center justify-content-center bg-white">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger">@Portuguese.OP_OrderNotFound</div>
    }
    else
    {
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div class="d-flex align-items-center">
                <button class="btn btn-light rounded-circle me-3 shadow-sm" @onclick="GoBack" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
                <h3 class="text-dark mb-0 fw-bold">@Portuguese.OP_Code: @order.LotCode</h3>
                <span class="badge @GetStatusClass(order.CurrentStatus) ms-3 px-3 py-2 rounded-pill">@TranslateStatus(order.CurrentStatus)</span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-danger shadow-sm" @onclick="DownloadIndividualReport">
                    <i class="fa-solid fa-file-pdf me-2"></i> @Portuguese.OP_ExportPDF
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-12 col-xl-8">
                <div class="card shadow-sm border-0 mb-4 rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold text-muted uppercase small">@Portuguese.OP_MainInfo</h5>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-soft p-3 rounded-3 me-3 text-primary"><i class="fa-solid fa-shirt fs-4"></i></div>
                                    <div>
                                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">@Portuguese.Product</small>
                                        <span class="text-dark fw-bold">@order.ProductName</span>
                                        <div class="xsmall text-muted">SKU: @order.ProductCode</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="bg-info-soft p-3 rounded-3 me-3 text-info"><i class="fa-solid fa-layer-group fs-4"></i></div>
                                    <div>
                                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">@Portuguese.Quantity</small>
                                        <span class="text-dark fw-bold">@order.Quantity</span>
                                        <div class="xsmall text-muted">
                                            @foreach(var s in order.Sizes) { <span class="badge bg-light text-dark border me-1">@s.Size: @s.Quantity</span> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success-soft p-3 rounded-3 me-3 text-success"><i class="fa-solid fa-calendar-check fs-4"></i></div>
                                    <div>
                                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">@Portuguese.OP_CreationDate</small>
                                        <span class="text-dark">@order.CreatedAt.ToLocalTime().ToString("d/M/yyyy")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <div class="bg-warning-soft p-3 rounded-3 me-3 text-warning"><i class="fa-solid fa-truck-fast fs-4"></i></div>
                                    <div>
                                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">@Portuguese.OP_EstimatedDelivery</small>
                                        <span class="text-dark fw-bold">@order.EstimatedCompletionAt.ToLocalTime().ToString("d/M/yyyy")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4 rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold text-muted uppercase small"><i class="fa-solid fa-gears me-2"></i>@Portuguese.OP_Controls</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            @if (order.CurrentStatus != "Completed" && order.CurrentStatus != "Cancelled")
                            {
                                <button class="btn btn-primary px-4 shadow-sm" @onclick="AdvanceStage" disabled="@isActionInProgress">
                                    <i class="fa-solid fa-forward-step me-2"></i> @Portuguese.OP_AdvanceStage
                                </button>
                                <button class="btn btn-outline-primary px-4" @onclick="ShowPartialOutput" disabled="@isActionInProgress">
                                    <i class="fa-solid fa-list-check me-2"></i> @Portuguese.OP_PartialOutput
                                </button>
                                <button class="btn btn-outline-warning px-4" @onclick="ShowQA" disabled="@isActionInProgress">
                                    <i class="fa-solid fa-triangle-exclamation me-2"></i> @Portuguese.Nav_QA
                                </button>
                                <button class="btn btn-success px-4 shadow-sm ms-auto" @onclick="FinalizeOrder" disabled="@(isActionInProgress || order.CurrentStatus == "Completed")">
                                    <i class="fa-solid fa-check-double me-2"></i> @Portuguese.OP_MarkCompleted
                                </button>
                            }
                        </div>

                        <div class="d-flex flex-wrap gap-2 pt-3 border-top">
                            <AuthorizeView Roles="Administrator,Leader">
                                <button class="btn btn-light btn-sm" @onclick="ShowAssignment">
                                    <i class="fa-solid fa-user-tag me-1"></i> @Portuguese.OP_AssignOperator
                                </button>
                                <button class="btn btn-light btn-sm" @onclick="ShowStageChange">
                                    <i class="fa-solid fa-rotate-left me-1"></i> @Portuguese.OP_ChangeStage
                                </button>
                            </AuthorizeView>
                            <button class="btn btn-light btn-sm" @onclick="ShowHistory">
                                <i class="fa-solid fa-clock-rotate-left me-1"></i> @Portuguese.OP_History
                            </button>
                            <button class="btn btn-light btn-sm" @onclick="LoadDefects">
                                <i class="fa-solid fa-bug me-1"></i> @Portuguese.Nav_QA (@defects.Count)
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Histórico Visual -->
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">
                        <div class="timeline">
                            @if (history != null && history.Any())
                            {
                                @foreach (var item in history.OrderByDescending(h => h.ChangedAt))
                                {
                                    <div class="timeline-item pb-4">
                                        <div class="d-flex">
                                            <div class="timeline-marker bg-primary-soft text-primary"><i class="fa-solid fa-history"></i></div>
                                            <div class="ms-3">
                                                <div class="fw-bold text-dark">@TranslateStage(item.NewStage)</div>
                                                <div class="small text-muted mb-1">@item.ChangedAt.ToLocalTime().ToString("g") @Portuguese.OP_By: @item.UserName</div>
                                                <div class="badge @GetStatusClass(item.NewStatus) xsmall">@TranslateStatus(item.NewStatus)</div>
                                                @if (!string.IsNullOrEmpty(item.Note))
                                                {
                                                    <div class="mt-2 p-2 bg-light rounded small italic">"@item.Note"</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-header bg-white border-0 pt-4 px-4 text-center">
                        <h5 class="card-title mb-0 fw-bold text-muted uppercase small">@Portuguese.OP_CurrentAssignment</h5>
                    </div>
                    <div class="card-body text-center pb-4">
                        <img src="@(string.IsNullOrEmpty(order.AssignedUserAvatar) ? "/img/avatars/avatar.jpg" : order.AssignedUserAvatar)" 
                             class="rounded-circle shadow-sm border mb-3" width="80" height="80" alt="Avatar" />
                        <h5 class="fw-bold mb-1 text-dark">@(order.AssignedUserName ?? Portuguese.OP_Unassigned)</h5>
                        <p class="text-muted small mb-3">@Portuguese.OP_OperatorAssigned</p>
                        @if (!string.IsNullOrEmpty(order.SewingTeamName))
                        {
                            <div class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill"><i class="fa-solid fa-people-group me-2"></i>@order.SewingTeamName</div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="card-title mb-0 fw-bold text-muted uppercase small">@Portuguese.OP_ProductionMetrics</h5>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="progress-steps">
                            <div class="step @GetStepClass("Cutting")">
                                <div class="step-icon">@((order.CurrentStage == "Cutting") ? "" : "")</div>
                                <div class="step-label">@Portuguese.Stage_Cutting</div>
                                <div class="step-status">@GetStepStatus("Cutting")</div>
                            </div>
                            <div class="step @GetStepClass("Sewing")">
                                <div class="step-icon">@((order.CurrentStage == "Sewing") ? "" : "")</div>
                                <div class="step-label">@Portuguese.Stage_Sewing</div>
                                <div class="step-status">@GetStepStatus("Sewing")</div>
                            </div>
                            <div class="step @GetStepClass("Review")">
                                <div class="step-icon">@((order.CurrentStage == "Review") ? "" : "")</div>
                                <div class="step-label">@Portuguese.Stage_Review</div>
                                <div class="step-status">@GetStepStatus("Review")</div>
                            </div>
                            <div class="step @GetStepClass("Packaging")">
                                <div class="step-icon">@((order.CurrentStage == "Packaging") ? "" : "")</div>
                                <div class="step-label">@Portuguese.Stage_Packaging</div>
                                <div class="step-status">@GetStepStatus("Packaging")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* MODALES *@
@if (showPartialModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold">@Portuguese.OP_PartialOutput - @TranslateStage(order?.CurrentStage)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showPartialModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small mb-4">@Portuguese.OP_PartialOutputDesc</p>
                    <table class="table table-sm table-borderless">
                        <thead>
                            <tr class="xsmall fw-bold text-muted">
                                <th>@Portuguese.OP_Size</th>
                                <th>@Portuguese.OP_TotalOrder</th>
                                <th>@Portuguese.OP_Remaining</th>
                                <th style="width: 100px;">@Portuguese.OP_PiecesCompleted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in order.Sizes)
                            {
                                <tr>
                                    <td class="fw-bold">@s.Size</td>
                                    <td>@s.Quantity</td>
                                    <td>@(s.Quantity - (defects.Where(d => d.Reason.Contains(s.Size)).Sum(d => d.Quantity)))</td> @* Logic mock *@
                                    <td><input type="number" class="form-control form-control-sm" @bind="sizeOutputs[s.Id]" min="0" max="@s.Quantity" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-light" @onclick="() => showPartialModal = false">@Portuguese.Cancel</button>
                    <button class="btn btn-primary px-4" @onclick="SavePartialOutput" disabled="@isSavingPartial">
                        @if(isSavingPartial) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        @Portuguese.OP_SaveProduction
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private ProductionOrderDto? order;
    private List<ProductionHistoryDto> history = new();
    private List<QADefectDto> defects = new();
    private bool loading = true;
    private bool isActionInProgress = false;
    private bool showPartialModal = false;
    private bool isSavingPartial = false;
    private Dictionary<int, int> sizeOutputs = new();

    protected override async Task OnInitializedAsync()
    {
        SignalR.OnUpdateReceived += async (opId, stage, status) => {
            if (opId == Id) await LoadData();
        };
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            loading = true;
            var response = await QueryClient.GetProductionOrderByIdAsync(Id);
            if (response != null && response.Success && response.Data != null)
            {
                order = response.Data;
                sizeOutputs = order.Sizes.ToDictionary(s => s.Id, _ => 0);
                var histResp = await QueryClient.GetHistoryByProductionOrderIdAsync(Id);
                if (histResp != null && histResp.Success) history = histResp.Data;
                await LoadDefects();
            }
        }
        catch (Exception ex) { ToastService.ShowToast(ex.Message, ToastLevel.Error); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task LoadDefects()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<QADefectDto>>>($"api/QA/orders/{Id}/defects");
            if (resp != null && resp.Success) defects = resp.Data ?? new();
        }
        catch { }
    }

    private async Task SavePartialOutput()
    {
        if (isSavingPartial) return;
        try
        {
            isSavingPartial = true;
            var response = await LifecycleClient.RegisterPartialOutputAsync(Id, sizeOutputs);
            if (response.Success)
            {
                ToastService.ShowToast(response.Message ?? Portuguese.OP_SuccessPartialOutput, ToastLevel.Success);
                showPartialModal = false;
                await LoadData();
            }
            else 
            {
                ToastService.ShowToast(response.Message ?? Portuguese.OP_ErrorPartialOutput, ToastLevel.Error);
            }
        }
        catch (Exception ex) 
        { 
            ToastService.ShowToast(ex.Message, ToastLevel.Error); 
        }
        finally 
        { 
            isSavingPartial = false; 
            StateHasChanged();
        }
    }

    private void ShowPartialOutput() => showPartialModal = true;
    private void GoBack() => NavigationManager.NavigateTo("/orders");

    private async Task AdvanceStage()
    {
        if (isActionInProgress) return;
        isActionInProgress = true;
        try
        {
            var response = await LifecycleClient.AdvanceStageAsync(Id);
            if (response.Success) 
            {
                ToastService.ShowToast(response.Message ?? "Estágio avançado!", ToastLevel.Success);
                await LoadData();
            }
            else
            {
                ToastService.ShowToast(response.Message ?? "Erro ao avançar estágio.", ToastLevel.Error);
            }
        }
        catch (Exception ex) 
        { 
            ToastService.ShowToast(ex.Message, ToastLevel.Error); 
        }
        finally 
        { 
            isActionInProgress = false; 
            StateHasChanged();
        }
    }

    private async Task FinalizeOrder()
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", Portuguese.OP_FinalizeWarning))
        {
            if (isActionInProgress) return;
            isActionInProgress = true;
            try
            {
                var response = await LifecycleClient.UpdateStatusAsync(Id, ProductionStatus.Completed, "Concluído via UI");
                if (response.Success) 
                {
                    ToastService.ShowToast(response.Message ?? "Ordem finalizada!", ToastLevel.Success);
                    await LoadData();
                }
                else
                {
                    ToastService.ShowToast(response.Message ?? "Erro ao finalizar ordem.", ToastLevel.Error);
                }
            }
            catch (Exception ex) 
            { 
                ToastService.ShowToast(ex.Message, ToastLevel.Error); 
            }
            finally 
            { 
                isActionInProgress = false; 
                StateHasChanged();
            }
        }
    }

    private async Task DownloadIndividualReport()
    {
        try
        {
            var baseUrl = NavigationManager.BaseUri.TrimEnd('/');
            await JSRuntime.InvokeVoidAsync("open", $"{baseUrl}/api/ProductionOrders/{Id}/pdf", "_blank");
        }
        catch (Exception ex) { ToastService.ShowToast(ex.Message, ToastLevel.Error); }
    }

    private string TranslateStatus(string? status) => status?.ToLower() switch
    {
        "pending" => Portuguese.Pending,
        "inproduction" => Portuguese.Status_InProgress,
        "paused" => Portuguese.Status_Paused,
        "completed" => Portuguese.Status_Completed,
        "cancelled" => Portuguese.Cancelled,
        _ => status ?? ""
    };

    private string TranslateStage(string? stage) => stage?.ToLower() switch
    {
        "cutting" => Portuguese.Stage_Cutting,
        "sewing" => Portuguese.Stage_Sewing,
        "review" => Portuguese.Stage_Review,
        "packaging" => Portuguese.Stage_Packaging,
        _ => stage ?? ""
    };

    private string GetStatusClass(string? status) => status?.ToLower() switch
    {
        "completed" => "bg-success",
        "inproduction" => "bg-primary",
        "pending" => "bg-warning",
        "paused" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetStepClass(string stage)
    {
        if (order == null) return "pending";
        var stages = new[] { "Cutting", "Sewing", "Review", "Packaging" };
        var currentIdx = Array.IndexOf(stages, order.CurrentStage);
        var targetIdx = Array.IndexOf(stages, stage);
        if (order.CurrentStatus == "Completed") return "completed";
        if (targetIdx < currentIdx) return "completed";
        if (targetIdx == currentIdx) return "active";
        return "pending";
    }

    private string GetStepStatus(string stage)
    {
        var cls = GetStepClass(stage);
        return cls switch { "completed" => "Concluído", "active" => "Em Andamento", _ => "Pendente" };
    }

    private void ShowQA() => ToastService.ShowToast("Funcionalidade em desenvolvimento", ToastLevel.Info);
    private void ShowAssignment() => ToastService.ShowToast("Use a página de listagem para reatribuir", ToastLevel.Info);
    private void ShowStageChange() => ToastService.ShowToast("Avanço automático ativado", ToastLevel.Info);
    private void ShowHistory() => StateHasChanged();

    public async ValueTask DisposeAsync()
    {
        try { await SignalR.StopConnection(); } catch { }
    }
}
