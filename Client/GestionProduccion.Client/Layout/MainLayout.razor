@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject IJSRuntime JS
@inject GestionProduccion.Client.Services.ISignalRService SignalR
@inject GestionProduccion.Client.Services.ToastService ToastService
@inject GestionProduccion.Client.Services.UserStateService UserState
@using GestionProduccion.Client.Auth
@using GestionProduccion.Client.Components
@using GestionProduccion.Client.Resources
@using GestionProduccion.Client.Services
@implements IDisposable

@if (!_isSystemReady)
{
    <div class="vh-100 d-flex flex-column align-items-center justify-content-center bg-white">
        <div class="spinner-border text-primary" role="status"></div>
        <h5 class="text-muted fw-bold">Inicializando sistema...</h5>
    </div>
}
else
{
    <div class="wrapper @(_isSidebarCollapsed ? "sidebar-closed" : "sidebar-open") @UserState.ThemeName">
        <AuthorizeView>
            <Authorized>
                <NavMenu IsOpen="!_isSidebarCollapsed" OnSidebarCollapse="ToggleSidebar" />
            </Authorized>
        </AuthorizeView>

        <div class="main">
            <nav class="navbar navbar-expand navbar-light navbar-bg">
                <a class="sidebar-toggle js-sidebar-toggle" @onclick="ToggleSidebar">
                    <i class="fa-solid fa-bars align-self-center" style="font-size: 1.5rem; color: #495057;"></i>
                </a>

                <div class="ms-2 d-lg-none fw-bold text-primary text-truncate" style="max-width: 150px;">
                    @UserState.CompanyName
                </div>

                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav navbar-align ms-auto">
                        <AuthorizeView>
                            <Authorized>
                                <li class="nav-item">
                                    <button class="btn btn-sm btn-outline-danger border-0" @onclick="Logout" title="@Portuguese.Logout">
                                        <i class="fa-solid fa-right-from-bracket fs-4"></i>
                                        <span class="d-none d-md-inline ms-1">@Portuguese.Logout</span>
                                    </button>
                                </li>
                            </Authorized>
                            <NotAuthorized>
                                <li class="nav-item">
                                    <a href="/login" class="btn btn-primary">@Portuguese.Login</a>
                                </li>
                            </NotAuthorized>
                        </AuthorizeView>
                    </ul>
                </div>
            </nav>

            <main class="content">
                <div class="container-fluid p-0">
                    <ToastContainer />
                    @Body
                </div>
            </main>
        </div>

        <div class="sidebar-overlay @(_isSidebarCollapsed ? "" : "active")" @onclick="ToggleSidebar"></div>
    </div>
}

@code {
    private bool _isSidebarCollapsed = true;
    private bool _isSystemReady = false;

    protected override async Task OnInitializedAsync()
    {
        UserState.OnChange += StateHasChanged;
        UserState.OnChange += UpdateBodyClass;

        // Global Guard: Wait for backend to be ready and checked
        try
        {
            var setupReq = await Http.GetFromJsonAsync<bool>("api/auth/setup-required");
            
            // Try to load theme from config
            var config = await Http.GetFromJsonAsync<SystemConfigurationDto>("api/Configuration/public");
            if (config != null)
            {
                if (!string.IsNullOrEmpty(config.ThemeName))
                {
                    UserState.UpdateTheme(config.ThemeName);
                    UpdateBodyClass();
                }
                
                if (!string.IsNullOrEmpty(config.CompanyName))
                {
                    UserState.UpdateCompanyName(config.CompanyName);
                }
            }

            _isSystemReady = true;
        }
        catch
        {
            _isSystemReady = true; 
        }

        NavigationManager.LocationChanged += OnLocationChanged;
        
        // Start SignalR for global notifications
        try
        {
            var hubUrl = NavigationManager.ToAbsoluteUri("/productionHub").ToString();
            await SignalR.StartConnection(hubUrl);
            SignalR.OnMessageReceived += HandleGlobalMessage;
        }
        catch { }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && _isSystemReady)
        {
            UpdateBodyClass();
        }
    }

    private void HandleGlobalMessage(string message, string type)
    {
        InvokeAsync(() => {
            if (type == "LeaderChange")
            {
                ToastService.ShowToast(message, ToastLevel.Info, "Ranking Atualizado!");
            }
            else
            {
                ToastService.ShowToast(message, ToastLevel.Info, "Notificação");
            }
            StateHasChanged();
        });
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var isMobile = await CheckIfMobile();
        if (isMobile && !_isSidebarCollapsed)
        {
            _isSidebarCollapsed = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> CheckIfMobile()
    {
        try 
        {
            return await JS.InvokeAsync<int>("eval", "window.innerWidth") < 992;
        }
        catch { return false; }
    }

    private async void UpdateBodyClass()
    {
        try 
        {
            await JS.InvokeVoidAsync("eval", $"document.body.className = '{UserState.ThemeName}'");
        }
        catch { }
    }

    private void ToggleSidebar()
    {
        _isSidebarCollapsed = !_isSidebarCollapsed;
    }

    private async Task Logout()
    {
        var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
        await customAuthStateProvider.MarkUserAsLoggedOut();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
        UserState.OnChange -= UpdateBodyClass;
        NavigationManager.LocationChanged -= OnLocationChanged;
        SignalR.OnMessageReceived -= HandleGlobalMessage;
    }
}
